{
  "version": 2,
  "name": "alghadeer-sign",
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "requests.html",
      "use": "@vercel/static"
    },
    {
      "src": "logo.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/sign",
      "dest": "/api/sign.py"
    },
    {
      "src": "/api/receipt",
      "dest": "/api/receipt.py"
    },
    {
      "src": "/api/requests",
      "dest": "/api/requests.py"
    },
    {
      "src": "/api/auth",
      "dest": "/api/auth.py"
    },
    {
      "src": "/api/get_signature",
      "dest": "/api/get_signature.py"
    },
    {
      "src": "/api/check_env",
      "dest": "/api/check_env.py"
    },
    {
      "src": "/api/confirmed",
      "dest": "/api/confirmed.py"
    },
    {
      "src": "/api/history",
      "dest": "/api/history.py"
    },
    {
      "src": "/requests",
      "dest": "/requests.html"
    },
    {
      "src": "/logo.png",
      "dest": "/logo.png"
    },
    {
      "src": "/sign/(.*)",
      "dest": "/index.html?id=$1"
    },
    {
      "src": "/r/(.*)",
      "dest": "/index.html?id=$1"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
